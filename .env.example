# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=intelligence

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b

# Storage
AUDIO_STORAGE_PATH=./storage/audio

# Auth (Local Auth)
# For local dev, auth can be bypassed or use local JWT.
AUTH_ENABLED=false

# Email (Optional/Local)
# For offline use, email can be logged to console or a local SMTP server.
RESEND_API_KEY=

# Ports
API_RSS_PORT=8000
API_PODCAST_PORT=8001
